# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# Database connection (async driver required).
# Local development: SQLite. Production example: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Backend server port
PORT=8000

# Runtime environment: dev returns full stack traces on errors, prod hides them
ENVIRONMENT=dev
IS_LAMBDA=false

# AI service (OpenAI-compatible endpoint), required by translate and OCR features.
# Translation uses a text model (services/translate.py), OCR needs a vision model (services/ocr.py).
# DeepSeek example: APP_AI_BASE_URL=https://api.deepseek.com (text only, no vision)
APP_AI_BASE_URL=
APP_AI_KEY=

# Optional: object storage service used by routers/storage.py
# OSS_SERVICE_URL=
# OSS_API_KEY=

# Optional: Stripe payment (services/payment.py)
# STRIPE_SECRET_KEY=
